{
  "name": "@philiprehberger/next-image-components",
  "version": "0.1.5",
  "description": "Next.js Image wrappers with skeleton loading and error fallback",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "test": "node --test src/__tests__/index.test.mjs"
  },
  "peerDependencies": {
    "clsx": ">=2.0.0",
    "next": ">=14.0.0",
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "clsx": "^2.1.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "next",
    "nextjs",
    "image",
    "optimized",
    "skeleton",
    "fallback"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/philiprehberger/ts-next-image-components.git"
  },
  "homepage": "https://github.com/philiprehberger/ts-next-image-components#readme",
  "bugs": {
    "url": "https://github.com/philiprehberger/ts-next-image-components/issues"
  },
  "author": "Philip Rehberger",
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false
}
